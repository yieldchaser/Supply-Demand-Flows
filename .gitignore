# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# Secrets — NEVER commit
.env
.env.*
secrets.yaml
*.secrets

# Raw ingested data — gitignored, re-fetchable from source APIs
data/raw/

# Health observability — committed so we can track system health over time
!data/health/
!data/health/*.json

# Curated canonical data — committed as source of truth for dashboard
!data/curated/
!data/curated/**/*.parquet

# Alert idempotency state — committed so GHA jobs deduplicate across runs
!data/sent_alerts.json

# Playwright
.playwright/
playwright-report/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
